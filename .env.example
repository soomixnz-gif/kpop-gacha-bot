# .env.example

# Discord bot token
DISCORD_TOKEN=your_discord_token_here

# Database connection URL
DATABASE_URL=your_database_url_here

# Bot prefix
BOT_PREFIX=!

# Bot version
BOT_VERSION=1.0.0

# Game economy configuration
# Example of setting game economy variables
GAME_CURRENCY=coins
GAME_REWARD_MULTIPLIER=1.0
